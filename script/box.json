      "id": "JD_Cookies",
      "name": "京东账号",
      "keys": [
        "CookiesJD",
        "cks_get_mute"
      ],
      "descs_html": [
        "若需要方便浏览：右上角菜单->打开调试模式->调试页面地址",
        "<a href='https://raw.githubusercontent.com/dompling/chavyleung-boxjs/boxjs/box/chavy.boxjs.html' target='_blank'>调试页面地址</a>"
      ],
      "settings": [
        {
          "id": "cks_get_mute",
