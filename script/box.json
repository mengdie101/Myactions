          "name": "CK 列表",
          "val": "",
          "type": "textarea",
          "autoGrow": false,
          "rows": 8,
          "desc": "CK 列表 (JSON 格式)",
          "primary": [
            "userName"
          ],
          "child": []
        }
      ],
      "icons": [
        "https://raw.githubusercontent.com/Orz-3/mini/master/jd.png",
        "https://raw.githubusercontent.com/Orz-3/task/master/jd.png"
